	    //先编译,返回文件
	     synchronized static void compile(String code,String table) throws Exception {
	    	File file = new File(Constants.BASEDIR+"/"+table+".java"); //选择文件夹
	    	if(file.exists()){
	             System.out.println("java文件已经存在！");
	         }
	       // 获得类名
