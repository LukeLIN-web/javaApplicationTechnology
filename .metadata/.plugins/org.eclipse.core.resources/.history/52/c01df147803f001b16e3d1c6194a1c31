package dto;

import java.sql.*;
import java.util.Vector;

public class People {
    private int id;
    private String name;
    private int age;
    private String address;
    Vector vt = new Vector(); 
    public People() {
    	Init();
    	Statement s = null;
    	try {
    		ResultSet rs = s.executeQuery("select name from people");
    		while(rs.next() ) {
    			id = rs.getInt(id); 
    			String add = rs.getString("address");
    			age = rs.getInt("age");
    			String name = rs.getString("address");
    			People p  = new People(id, name, age, add);
    			vt.add(p);
    		}
    	}
    }

    private void Init() {
		// TODO Auto-generated method stub
    	String url = "jdbc:derby:Derby_data\\\\dedb";
    	try {
			 Connection conn = DriverManager.getConnection(url);
			 s = conn.createStatement();
		} catch (SQLException e) { 
		e.printStackTrace();
		}
	}

	public People(int id, String name, int age, String address) {
        this.id = id;
        this.name = name;
        this.age = age;
        this.address = address;
    }

    public int getId() {
        return id;
    }
    public void setId(int id) {
        this.id = id;
    }

    public String getName() {
        return name;
    }

    public void setName(String name) {
        this.name = name;
    }

    public int getAge() {
        return age;
    }

    public void setAge(int age) {
        this.age = age;
    }

    public String getAddress() {
        return address;
    }

    public void setAddress(String address) {
        this.address = address;
    }
    @Override
    public String toString() {
        return "People{" +
                "id=" + id +
                ", name='" + name + '\'' +
                ", age=" + age +
                ", address='" + address + '\'' +
                '}';
    }
}
